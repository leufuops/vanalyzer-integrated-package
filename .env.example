# vAnalyzer Configuration Template
# This file is automatically generated by 'vanalyzer init'
# Manual creation is not recommended - use the init wizard instead

# User-Configurable Settings
VANALYZER_HOSTNAME=reports.company.com  # Required: Your access hostname
DB_USER=vanalyzer                       # Database username (default: vanalyzer)
DB_NAME=vanalyzer                       # Database name (default: vanalyzer)  
SYNC_INTERVAL=6                         # Hours between data syncs (default: 6, number only)
METABASE_MEMORY=2g                      # Memory allocation for Metabase (default: 2g)

# External Vulnerability Data (Optional)
EXTERNAL_DATA_ENABLED=false              # Enable KEV + EPSS data loading (true/false)
EPSS_URL=https://epss.empiricalsecurity.com/epss_scores-current.csv.gz  # EPSS data source
KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json  # KEV data source

# Sensitive data stored in Docker secrets (NOT in this file):
# - API Key (secret: api_key)
# - Dashboard ID (secret: dashboard_id)
# - Database Password (secret: postgres_password)

# Note: All other settings are auto-generated during initialization